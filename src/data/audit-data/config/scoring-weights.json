{
  "$comment": "Scoring weights for AI-readiness audit v2.1. Organised by cluster, matching the 7-cluster / 44-dimension structure. Cluster weights sum to 1.00. Within each cluster, dimension weights are relative (sum to 1.00 per cluster). The overall score is: sum of (cluster_score x cluster_weight). v2.1 replaces the v1.4 flat dimension weights.",
  "version": "2.1",

  "scoring_methodology": {
    "dimension_scale": "0-4 integers: 0=not present, 1=major gaps, 2=inconsistent, 3=minor issues, 4=fully implemented. Tier 2 craft dimensions use 0/1/2.",
    "cluster_score_formula": "average of scored dimension scores (null excluded) x 25, producing 0-100",
    "overall_score_formula": "sum of (cluster_score x cluster_weight) across all clusters with scored dimensions",
    "override_rule": "If any sub-check within a dimension scores 0, dimension severity is forced to blocker regardless of composite score",
    "severity_from_score": "0-1=blocker, 2=warning, 3=note, 4=pass"
  },

  "severity_thresholds": {
    "$comment": "Applied per dimension based on raw 0-4 score. Client configs may override.",
    "default": {
      "blocker": { "below": 2 },
      "warning": { "at": 2 },
      "note":    { "at": 3 },
      "pass":    { "at": 4 }
    },
    "overrides": {}
  },

  "phase_readiness_thresholds": {
    "pass": {
      "overall_minimum": 75,
      "max_blockers": 0,
      "max_warnings": null
    },
    "conditional_pass": {
      "overall_minimum": 50,
      "max_blockers": 0,
      "max_warnings": null
    },
    "not_ready": {
      "$comment": "Any dimension-level blocker OR overall < 50"
    }
  },

  "clusters": {

    "0_prerequisites": {
      "weight": 0.05,
      "$comment": "Gate cluster. Low weight but a failing score (below 2) flags all downstream clusters as conditionally valid.",
      "dimensions": {
        "0.1_platform_architecture_clarity": {
          "weight": 1.00,
          "evidence": "Figma + Code"
        }
      }
    },

    "1_token_and_variable_system": {
      "weight": 0.25,
      "$comment": "Foundation layer. Highest cluster weight. If tokens fail, nothing above can be trusted.",
      "dimensions": {
        "1.1_token_implementation": {
          "weight": 0.20,
          "evidence": "Figma"
        },
        "1.2_alias_chain_integrity": {
          "weight": 0.15,
          "evidence": "Figma"
        },
        "1.3_token_architecture_depth": {
          "weight": 0.25,
          "evidence": "Figma + Code"
        },
        "1.4_primitive_naming": {
          "weight": 0.10,
          "evidence": "Figma + Code"
        },
        "1.5_token_format_machine_readability": {
          "weight": 0.10,
          "evidence": "Code"
        },
        "1.6_token_documentation": {
          "weight": 0.20,
          "evidence": "Figma + Code"
        }
      }
    },

    "2_component_quality": {
      "weight": 0.15,
      "$comment": "Structural layer built on tokens.",
      "dimensions": {
        "2.1_component_to_token_binding": {
          "weight": 0.40,
          "evidence": "Figma (REST + MCP)"
        },
        "2.2_component_api_composability": {
          "weight": 0.20,
          "evidence": "Code only"
        },
        "2.3_variant_completeness": {
          "weight": 0.25,
          "evidence": "Figma + Code"
        },
        "2.4_escape_hatch_usage": {
          "weight": 0.15,
          "evidence": "Code only"
        }
      }
    },

    "3_documentation_readiness": {
      "weight": 0.25,
      "$comment": "Tied highest cluster weight with tokens. Whether the system can explain itself to an agent. MUI v2.0 scored 16.7 here -- the worst cluster. Renamed from 'documentation_and_intent' in ADR 010.",
      "dimensions": {
        "3.1_functional_intent_coverage": {
          "weight": 0.25,
          "evidence": "Figma + Code"
        },
        "3.2_documentation_indexing": {
          "weight": 0.15,
          "evidence": "Code"
        },
        "3.3_intent_quality": {
          "weight": 0.30,
          "evidence": "Figma + Code",
          "$comment": "Highest weight in cluster. Scored against six-level documentation hierarchy."
        },
        "3.4_usage_guidance_structure": {
          "weight": 0.15,
          "evidence": "Code"
        },
        "3.5_in_file_documentation_structure": {
          "weight": 0.15,
          "evidence": "Figma"
        }
      }
    },

    "4_design_quality_baseline": {
      "weight": 0.10,
      "$comment": "Universal quality criteria. Lower cluster weight because these are quality signals, not blocking factors for agent operation. 27 dimensions across two tiers.",
      "dimensions": {
        "4.1_interaction_targets":              { "weight": 0.05, "tier": 1, "evidence": "Figma + Code" },
        "4.2_contrast_ratios":                  { "weight": 0.05, "tier": 1, "evidence": "Figma + Code" },
        "4.3_type_scale_consistency":           { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.4_type_completeness":                { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.5_spacing_scale_regularity":         { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.6_grid_and_layout_system":           { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.7_motion_duration_ranges":           { "weight": 0.03, "tier": 1, "evidence": "Figma + Code" },
        "4.8_motion_easing":                    { "weight": 0.03, "tier": 1, "evidence": "Figma + Code" },
        "4.9_focus_state_presence":             { "weight": 0.05, "tier": 1, "evidence": "Figma + Code" },
        "4.10_error_state_coverage":            { "weight": 0.05, "tier": 1, "evidence": "Figma + Code" },
        "4.11_loading_state_coverage":          { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.12_empty_state_coverage":            { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.13_colour_system_structure":         { "weight": 0.04, "tier": 1, "evidence": "Figma + Code" },
        "4.14_icon_sizing_consistency":         { "weight": 0.03, "tier": 1, "evidence": "Figma + Code" },
        "4.15_elevation_shadow_system":         { "weight": 0.03, "tier": 1, "evidence": "Figma + Code" },
        "4.16_visibility_of_system_status":     { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.17_match_between_system_and_real_world": { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.18_user_control_and_freedom":        { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.19_consistency_and_standards":        { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.20_error_prevention":                { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.21_recognition_rather_than_recall":  { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.22_flexibility_and_efficiency":      { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.23_aesthetic_and_minimalist_design":  { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.24_error_recovery":                  { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.25_help_and_documentation":          { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.26_visual_hierarchy":                { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" },
        "4.27_visual_rhythm_and_proportion":    { "weight": 0.03, "tier": 2, "evidence": "Figma + Code" }
      }
    },

    "5_governance_and_ecosystem": {
      "weight": 0.08,
      "$comment": "System hygiene. Low weight because governance does not directly impair a single audit or code generation run.",
      "dimensions": {
        "5.1_naming_convention_consistency":              { "weight": 0.20, "evidence": "Figma + Code" },
        "5.2_versioning_and_changelog_discipline":       { "weight": 0.15, "evidence": "Code" },
        "5.3_contribution_standards":                    { "weight": 0.15, "evidence": "Code" },
        "5.4_deprecation_patterns":                      { "weight": 0.15, "evidence": "Figma + Code" },
        "5.5_test_coverage":                             { "weight": 0.15, "evidence": "Code only" },
        "5.6_adoption_visibility":                       { "weight": 0.10, "evidence": "Code only" },
        "5.7_code_consistency_and_pattern_predictability": { "weight": 0.10, "evidence": "Code only" }
      }
    },

    "6_design_to_code_parity": {
      "weight": 0.12,
      "$comment": "Cross-platform coherence. Requires both Figma and code evidence. Entire cluster scores null when code repo is absent.",
      "dimensions": {
        "6.1_token_value_parity":                { "weight": 0.25, "evidence": "Both" },
        "6.2_token_naming_parity":               { "weight": 0.15, "evidence": "Both" },
        "6.3_component_naming_parity":           { "weight": 0.15, "evidence": "Both" },
        "6.4_variant_and_state_coverage_parity": { "weight": 0.15, "evidence": "Both" },
        "6.5_behaviour_parity":                  { "weight": 0.15, "evidence": "Both" },
        "6.6_documentation_of_parity_gaps":      { "weight": 0.15, "evidence": "Both" }
      }
    }
  }
}
